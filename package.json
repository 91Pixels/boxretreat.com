{
  "name": "boxretreat-vacation-rental",
  "version": "1.0.0",
  "description": "BoxRetreat Luquillo — Vacation rental with Stripe payments",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --forceExit",
    "test:security": "jest tests/security-roles.test.js --verbose --no-coverage",
    "test:finance": "jest tests/financial-logic.test.js --verbose --no-coverage",
    "test:unit": "jest tests/security-roles.test.js tests/financial-logic.test.js --verbose --no-coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:security": "playwright test tests/e2e/admin-security.spec.js --project=chromium",
    "test:e2e:financial": "playwright test tests/e2e/admin-financial.spec.js --project=chromium",
    "test:e2e:ui": "playwright test --headed --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "stripe": "^16.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server.js",
      "lib/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80
      }
    }
  }
}
