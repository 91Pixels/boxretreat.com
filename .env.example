# ============================================================
# BoxRetreat — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ============================================================

# --- Stripe Keys ---
# Get these from: https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ for testing (no real charges)
# Use sk_live_ / pk_live_ for production

STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# --- Test cards (Stripe test mode) ---
# Visa success:          4242 4242 4242 4242
# 3D Secure:             4000 0025 0000 3155
# Decline (generic):     4000 0000 0000 0002
# Decline (funds):       4000 0000 0000 9995
# Klarna:                Use Klarna test credentials in Stripe's test popup
# Affirm:                Use Affirm test credentials in Stripe's test popup
# Expiry: any future date  |  CVV: any 3 digits  |  ZIP: any 5 digits

# --- Server ---
PORT=3000
BASE_URL=http://localhost:3000
